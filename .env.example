SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
DEBATE_CHANNEL_ID=C0123456789
CODING_CHANNEL_ID=C9876543210
MAX_DEBATE_ROUNDS=10
CONSENSUS_EARLY_ROUNDS=5

# Bridge mode channels
SR_AGENT_CHANNEL_ID=
SR_AGENT_WORK_DIR=C:\path\to\stockradar
TC_AGENT_CHANNEL_ID=
TC_AGENT_WORK_DIR=C:\path\to\tc_manager

# Coding mode allowed working directories (semicolon-separated)
CODING_ALLOWED_DIRS=C:\path\to\project1;C:\path\to\project2

# Gemini 계열 CLI 바이너리 (2026-06-18 Gemini CLI 종료 대비)
# - gemini (기본): 기존 Gemini CLI 사용
# - agy: Antigravity CLI 사용 (사전 `agy -i` 인터랙티브 OAuth 1회 필요)
GEMINI_CLI_BINARY=gemini
